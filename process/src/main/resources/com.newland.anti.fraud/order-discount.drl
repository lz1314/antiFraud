package com.example.rules;

import com.example.model.Order;
import com.example.model.Order.OrderItem;
import java.math.BigDecimal;
import java.math.RoundingMode;

// 规则：验证订单有效性
rule "Validate Order - Check Items"
    ruleflow-group "order-validation"
    when
        $order: Order(items.size() == 0)
    then
        $order.setStatus("INVALID");
        System.out.println("订单验证失败：订单项为空");
        update($order);
end

rule "Validate Order - Check Amount"
    ruleflow-group "order-validation"
    when
        $order: Order(totalAmount == null || totalAmount.compareTo(BigDecimal.ZERO) <= 0)
    then
        $order.setStatus("INVALID");
        System.out.println("订单验证失败：订单金额无效");
        update($order);
end

rule "Validate Order - Valid"
    ruleflow-group "order-validation"
    when
        $order: Order(status != "INVALID")
    then
        $order.setStatus("VALIDATED");
        System.out.println("订单验证通过");
        update($order);
end

// 规则：VIP会员折扣
rule "VIP Member Discount"
    ruleflow-group "order-processing"
    when
        $order: Order(customerTier == "VIP", totalAmount != null)
    then
        BigDecimal discount = $order.getTotalAmount().multiply(new BigDecimal("0.20"));
        $order.setDiscountAmount(discount);
        System.out.println("VIP会员获得20%折扣: " + discount);
        update($order);
end

// 规则：GOLD会员折扣
rule "GOLD Member Discount"
    ruleflow-group "order-processing"
    when
        $order: Order(customerTier == "GOLD", totalAmount != null)
    then
        BigDecimal discount = $order.getTotalAmount().multiply(new BigDecimal("0.15"));
        $order.setDiscountAmount(discount);
        System.out.println("GOLD会员获得15%折扣: " + discount);
        update($order);
end

// 规则：SILVER会员折扣
rule "SILVER Member Discount"
    ruleflow-group "order-processing"
    when
        $order: Order(customerTier == "SILVER", totalAmount != null)
    then
        BigDecimal discount = $order.getTotalAmount().multiply(new BigDecimal("0.10"));
        $order.setDiscountAmount(discount);
        System.out.println("SILVER会员获得10%折扣: " + discount);
        update($order);
end

// 规则：普通会员无折扣
rule "Normal Member Discount"
    ruleflow-group "order-processing"
    when
        $order: Order(customerTier == "NORMAL" || customerTier == null)
    then
        $order.setDiscountAmount(BigDecimal.ZERO);
        System.out.println("普通会员无折扣");
        update($order);
end

// 规则：大额订单额外优惠
rule "Large Order Additional Discount"
    ruleflow-group "order-processing"
    when
        $order: Order(totalAmount != null,
                      totalAmount.compareTo(new BigDecimal("1000")) > 0,
                      discountAmount != null)
    then
        BigDecimal additionalDiscount = new BigDecimal("50");
        $order.setDiscountAmount($order.getDiscountAmount().add(additionalDiscount));
        System.out.println("大额订单额外优惠50元");
        update($order);
end

// 规则：计算最终金额
rule "Calculate Final Amount"
    ruleflow-group "order-processing"
    when
        $order: Order(totalAmount != null, discountAmount != null)
    then
        BigDecimal finalAmount = $order.getTotalAmount().subtract($order.getDiscountAmount());
        finalAmount = finalAmount.max(BigDecimal.ZERO);
        $order.setFinalAmount(finalAmount);
        $order.setStatus("PROCESSED");
        System.out.println("最终金额: " + finalAmount);
        update($order);
end